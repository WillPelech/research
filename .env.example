# Required: where the weekly digest should go
DIGEST_TO_EMAIL=you@example.com

# From address (must be verified in Resend, or allowed by your SMTP provider)
DIGEST_FROM_EMAIL=Research Digest <onboarding@resend.dev>

# --- Email via Resend (recommended) ---
RESEND_API_KEY=re_xxxxxxxx

# --- Or email via SMTP (omit RESEND_API_KEY to use this) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true

# Optional
# DRY_RUN=0
